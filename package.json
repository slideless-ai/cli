  "bugs": {
    "url": "https://github.com/slideless-ai/cli/issues"
  },
  "homepage": "https://slideless.ai",
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
